# =============================================================================
# CONTROLAI - ENVIRONMENT VARIABLES
# =============================================================================
# NOTE: Copy this file to .env.local and fill in real values
# =============================================================================

# SUPABASE (Database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# AI PROVIDERS - HYBRID MOTOR
# =============================================================================

# GROQ API (Free/Low-Cost)
# Get your key at: https://console.groq.com
# Free Plan: 30 req/min, FREE
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxx

# OPENAI API (Premium)
# Get your key at: https://platform.openai.com/api-keys
# Plan: GPT-4o Mini (economical), USD $0.15/$0.60 per 1M tokens
OPENAI_API_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# NEXT.JS CONFIGURATION
# =============================================================================

NEXT_PUBLIC_APP_NAME=ControlAI
NEXT_PUBLIC_APP_VERSION=2.0.0

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=info
DEBUG=false

# =============================================================================
# DEPLOYMENT
# =============================================================================

# Vercel (Production)
VERCEL_URL=https://controlai.vercel.app
NODE_ENV=production
