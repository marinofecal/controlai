# =============================================================================
# CONTROLAI - ENVIRONMENT VARIABLES
# =============================================================================
# IMPORTANTE: Copia este archivo a .env.local y rellena los valores reales
# =============================================================================

# SUPABASE (Base de datos)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# AI PROVIDERS - MOTOR HÍBRIDO
# =============================================================================

# GROQ API (Gratis/Económico)
# Obtén tu key en: https://console.groq.com
# Plan Gratuito: 30 req/min, GRATIS
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxx

# OPENAI API (Premium)
# Obtén tu key en: https://platform.openai.com/api-keys
# Plan: GPT-4o Mini (económico), USD $0.15/$0.60 por 1M tokens
OPENAI_API_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# NEXT.JS CONFIGURATION
# =============================================================================

NEXT_PUBLIC_APP_NAME=ControlAI
NEXT_PUBLIC_APP_VERSION=2.0.0

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=info
DEBUG=false

# =============================================================================
# DEPLOYMENT
# =============================================================================

# Vercel (Producción)
VERCEL_URL=https://controlai.vercel.app
NODE_ENV=production
